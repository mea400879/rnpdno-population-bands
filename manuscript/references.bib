	langid = {english},
	file = {PDF:/home/marco/Zotero/storage/5EEIISEV/Rios - 2013 - Why did Mexico become so violent A self-reinforcing violent equilibrium caused by competition and e.pdf:application/pdf},
}

@article{fuentes_shifting_2015,
	title = {Shifting the Status Quo: Constitutional Reforms in Chile},
	volume = {57},
	rights = {https://www.cambridge.org/core/terms},
