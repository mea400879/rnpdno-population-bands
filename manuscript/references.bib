	langid = {english},
	file = {PDF:/home/marco/Zotero/storage/5C6KPU96/Atuesta - 2025 - The Connection Between Drug-Related Detentions and Drug-Related Violence Another Failure of the War.pdf:application/pdf},
}

@article{pocoroba_unbearable_2025,
	title = {The Unbearable Uncertainty of Being on the Front Street-level Military in the Mexican War on Drugs},
	volume = {67},
	rights = {https://www.cambridge.org/core/terms},
	issn = {1531-426X, 1548-2456},
	url = {https://www.cambridge.org/core/product/identifier/S1531426X24000207/type/journal_article},
	doi = {10.1017/lap.2024.20},
	abstract = {Since the so-called war on drugs began in Mexico in 2006, the military has been the leading actor in charge of the government’s public security policy, undertaking tasks that should be carried out by the police. Analyses of this security strategy are based on quantitative methods and have focused on its results: e.g., an increase in the homicide rate or the committing of human rights violations. In contrast, based on in-depth interviews, this article explores the testimony of military personnel to understand what they experience in the field. Contrary to what the existing literature argues, which maintains that the military acts with a logic of war, this article shows that the situation is far more complex: they act in a scenario characterized by improvisation, facing the dilemma between acting and being accused of human rights or not acting and being accused of disobedience.},
	pages = {19--35},
	number = {1},
	journaltitle = {Latin American Politics and Society},
	shortjournal = {Lat Am Polit Soc},
	author = {Pocoroba, Alejandro and Atuesta, Laura H. and Treviño-Rangel, Javier},
	urldate = {2026-03-12},
